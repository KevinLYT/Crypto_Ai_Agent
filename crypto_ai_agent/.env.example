# 复制为 .env 后填写。未设置 OPENAI_API_KEY 时：POST /analyze-wallet 走规则模板；POST /agent/analyze-wallet 会返回 503（LangChain 工具调用需要 Key）。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LOG_LEVEL=INFO

# Feature heuristics
LARGE_TX_MULTIPLIER=3.0
HIGH_FREQ_TX_PER_DAY=8.0
HIGH_FREQ_BURST_WINDOW_SECONDS=3600
HIGH_FREQ_BURST_MIN_COUNT=6
